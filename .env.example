# Optional: bake a TMDB key into the build instead of entering it in Settings.
# Note: any key in a client-side build is visible to whoever can open the site,
# so only do this for a private/personal deployment.
VITE_TMDB_API_KEY=

# Firebase config for cross-device sync (see README "Cloud sync" section).
# These values are not secret - Firebase client config is meant to be public;
# access is controlled by firestore.rules, not by hiding this config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
